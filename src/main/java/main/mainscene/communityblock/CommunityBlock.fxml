<BorderPane maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefWidth="636.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.mainscene.peopleblock.PeopleBlockController">
   
   <stylesheets>
      <URL value="@peopleblock.css" />
   </stylesheets>

   <left>
      <Region minHeight="-Infinity" minWidth="-Infinity" prefHeight="75.0" prefWidth="91.0" BorderPane.alignment="CENTER" />
   </left>
   <center>
      <Label fx:id="communityName" text="Community_Name" BorderPane.alignment="CENTER_LEFT">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
   </center>
   <bottom>
      <VBox prefWidth="636.0" BorderPane.alignment="CENTER" />
   </bottom>
   <right>
      <StackPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="75.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="circleButtons" alignment="CENTER" mnemonicParsing="false" onAction="#AddFriend" text="+">
  				<font>
     			<Font name="Segoe UI Bold" size="18.0" /> </font>
			</Button>
            <Text fx:id="reqSentText" strokeType="OUTSIDE" strokeWidth="0.0" text="Joined to the Server!" textAlignment="CENTER" visible="false" wrappingWidth="71.859375">
               <font>
                  <Font name="Segoe UI Bold" size="14.0" />
               </font>
            </Text>
         </children>
      </StackPane>
   </right>
</BorderPane>
