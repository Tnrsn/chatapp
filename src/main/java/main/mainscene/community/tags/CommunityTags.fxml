   <graphic>
      <BorderPane prefHeight="200.0" prefWidth="200.0">
         <left>
            <Text fx:id="tagName" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" BorderPane.alignment="CENTER">
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin></Text>
         </left>
      </BorderPane>
   </graphic>
</Button>
