<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="background" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="482.0" prefWidth="368.0" spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.mainscene.community.CreateCommunityController"> 
    <padding>
        <Insets bottom="20" left="20" right="20" top="30" />
    </padding>
    <TextField fx:id="serverName" maxWidth="300.0" promptText="Server Name" />
    <TextField fx:id="serverTagsField" maxWidth="300.0" promptText="Server Tags (Art. Tech. Gaming, etc.)" />
   <TextArea fx:id="serverDescription" maxWidth="300.0" prefHeight="79.0" prefWidth="300.0" promptText="Server Description" wrapText="true" />
    <HBox alignment="TOP_CENTER" maxWidth="300.0" spacing="20">
        <ScrollPane fx:id="tagsScroll" fitToWidth="true" prefViewportHeight="180" prefViewportWidth="180" prefWidth="175.0">
            <content>
                <VBox fx:id="tagContainer" fillWidth="true" spacing="5" />
            </content>
         <HBox.margin>
            <Insets />
         </HBox.margin>
        </ScrollPane>
        <VBox alignment="CENTER" spacing="20">
         <CheckBox fx:id="isPublic" mnemonicParsing="false" selected="true" text="Public" />
            <Button fx:id="addTagButton" onAction="#AddTag" text="Add Tag" />
            <Button fx:id="createServerButton" onAction="#CreateServer" text="Create Server" textAlignment="CENTER" />
        </VBox>
    </HBox>
   <Label text="Press ESC to close this screen" />
</VBox>
