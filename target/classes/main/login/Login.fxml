<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
            prefHeight="400.0" prefWidth="500.0" styleClass="main-bg"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="main.login.LoginController">

   <stylesheets>
      <URL value="@login.css" />
   </stylesheets>

   <children>
      <BorderPane fx:id="toolBar" styleClass="teams-toolbar" prefHeight="39.0" prefWidth="500.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"> 
         <right>
            <Button fx:id="closeButton" mnemonicParsing="false" onAction="#closeWindow" text="✕" BorderPane.alignment="CENTER">
               <font>
                  <Font name="Segoe UI" size="14.0" />
               </font>
            </Button>
         </right>
      </BorderPane>
      
      <TextField fx:id="emailTextField" layoutX="100.0" layoutY="125.0" onAction="#Login" promptText="E-MAIL" styleClass="teams-input" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0">
         <font>
            <Font name="Segoe UI" size="16.0" />
         </font>
      </TextField>
      
      <PasswordField fx:id="passwordTextField" layoutX="100.0" layoutY="200.0" onAction="#Login" prefHeight="35.0" prefWidth="300.0" promptText="PASSWORD" styleClass="teams-input" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0">
         <font>
            <Font name="Segoe UI" size="16.0" />
         </font>
      </PasswordField>
      
      <Button alignment="CENTER" layoutX="100.0" layoutY="295.0" mnemonicParsing="false" onAction="#Register" prefHeight="38.0" prefWidth="140.0" text="Register" styleClass="button-secondary" AnchorPane.leftAnchor="100.0">
         <font>
            <Font name="Segoe UI Bold" size="15.0" />
         </font>
      </Button>

      <Button alignment="CENTER" layoutX="260.0" layoutY="295.0" mnemonicParsing="false" onAction="#Login" prefHeight="38.0" prefWidth="140.0" text="Login" styleClass="button-primary" AnchorPane.rightAnchor="100.0">
         <font>
            <Font name="Segoe UI Bold" size="15.0" />
         </font>
      </Button>
      
      <Label fx:id="errorText" layoutX="100.0" layoutY="252.0" styleClass="teams-error-label" text="error" visible="false">
         <font>
            <Font name="Segoe UI" size="13.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
